<?php
/**
 * @var \Zaca\Events\Block\Ludoteca\Landing $block
 * @var \Magento\Framework\Escaper $escaper
 */
$locations = $block->getLocations();
$capacityPerTable = $block->getCapacityPerTable();
$myBookings = $block->getMyActiveBookings();
$cancelUrl = $block->getCancelMyBookingUrl();
$formKey = $block->getFormKey();
?>
<div class="ludoteca-landing">
    <header class="ludoteca-landing-hero">
        <h1 class="ludoteca-landing-title"><?= $escaper->escapeHtml(__('Reserva mesa de ludoteca')) ?></h1>
        <p class="ludoteca-landing-intro">
            <?= $escaper->escapeHtml(__('Elige una tienda y reserva 1 o 2 mesas para venir a jugar dentro del horario comercial.')) ?>
        </p>
    </header>

    <?php if (!empty($myBookings)): ?>
        <section class="ludoteca-mybookings">
            <h2 class="ludoteca-mybookings-title"><?= $escaper->escapeHtml(__('Tus próximas reservas')) ?></h2>
            <ul class="ludoteca-mybookings-list">
                <?php foreach ($myBookings as $b): ?>
                    <li class="ludoteca-mybookings-item">
                        <div class="ludoteca-mybookings-info">
                            <div class="ludoteca-mybookings-head">
                                <strong><?= $escaper->escapeHtml($b['location_name']) ?></strong>
                                <span class="ludoteca-mybookings-date"><?= $escaper->escapeHtml($block->formatBookingDate($b['booking_date'])) ?></span>
                            </div>
                            <?php if (!empty($b['slots'])): ?>
                                <ul class="ludoteca-mybookings-slots">
                                    <?php foreach ($b['slots'] as $s): ?>
                                        <li>
                                            <?= $escaper->escapeHtml(sprintf('%s – %s', $s['start'], $s['end'])) ?>
                                            · <?= $escaper->escapeHtml(sprintf('%d %s', $s['tables'], __('mesa(s)')->render())) ?>
                                        </li>
                                    <?php endforeach; ?>
                                </ul>
                            <?php endif; ?>
                        </div>
                        <form method="post"
                              action="<?= $escaper->escapeUrl($cancelUrl) ?>"
                              class="ludoteca-mybookings-cancel-form"
                              onsubmit="return confirm(<?= $escaper->escapeJs(json_encode((string) __('¿Cancelar esta reserva?'))) ?>);">
                            <input type="hidden" name="form_key" value="<?= $escaper->escapeHtmlAttr($formKey) ?>"/>
                            <input type="hidden" name="booking_id" value="<?= (int) $b['booking_id'] ?>"/>
                            <button type="submit" class="ludoteca-mybookings-cancel">
                                <?= $escaper->escapeHtml(__('Cancelar reserva')) ?>
                            </button>
                        </form>
                    </li>
                <?php endforeach; ?>
            </ul>
        </section>
    <?php endif; ?>

    <?php if (empty($locations)): ?>
        <div class="ludoteca-empty">
            <p><?= $escaper->escapeHtml(__('Aún no hay tiendas con ludoteca configurada.')) ?></p>
        </div>
    <?php else: ?>
        <div class="ludoteca-grid">
            <?php foreach ($locations as $location):
                $tables = (int) $location->getData('total_tables');
                $slotCount = $block->getSlotCountFor((int) $location->getId());
                $address = $block->formatAddress($location);
                $url = $block->getStoreUrl((string) $location->getUrlKey());
            ?>
                <article class="ludoteca-card">
                    <div class="ludoteca-card-head">
                        <h2 class="ludoteca-card-title">
                            <a href="<?= $escaper->escapeUrl($url) ?>" class="ludoteca-card-title-link">
                                <?= $escaper->escapeHtml((string) $location->getName()) ?>
                            </a>
                        </h2>
                    </div>

                    <div class="ludoteca-card-body">
                        <p class="ludoteca-card-desc">
                            <?= $escaper->escapeHtml(__('Reserva 1 o 2 mesas para venir a jugar a esta tienda. Cada mesa admite hasta %1 personas.', $capacityPerTable)) ?>
                        </p>

                        <div class="ludoteca-card-meta">
                            <?php if ($address !== ''): ?>
                                <div class="ludoteca-meta-row">
                                    <span class="ludoteca-meta-icon" aria-hidden="true">📍</span>
                                    <span><?= $escaper->escapeHtml($address) ?></span>
                                </div>
                            <?php endif; ?>
                            <div class="ludoteca-meta-row">
                                <span class="ludoteca-meta-icon" aria-hidden="true">🪑</span>
                                <span>
                                    <?= $escaper->escapeHtml(__('%1 mesas (hasta %2 personas)', $tables, $tables * $capacityPerTable)) ?>
                                </span>
                            </div>
                            <?php if ($slotCount > 0): ?>
                                <div class="ludoteca-meta-row">
                                    <span class="ludoteca-meta-icon" aria-hidden="true">🕒</span>
                                    <span><?= $escaper->escapeHtml(__('%1 turnos al día', $slotCount)) ?></span>
                                </div>
                            <?php endif; ?>
                        </div>

                        <div class="ludoteca-card-actions">
                            <a href="<?= $escaper->escapeUrl($url) ?>" class="ludoteca-action ludoteca-action-primary">
                                <?= $escaper->escapeHtml(__('Ver disponibilidad')) ?>
                            </a>
                        </div>
                    </div>
                </article>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</div>

