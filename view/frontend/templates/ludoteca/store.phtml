<script>
(function () {
    var root = document.querySelector('.ludoteca-store');
    if (!root) { return; }
    var ctx = {
        locationId: parseInt(root.dataset.locationId, 10),
        totalTables: parseInt(root.dataset.totalTables, 10),
        loggedIn: root.dataset.isLoggedIn === '1',
        isClub: root.dataset.isClub === '1',
        hasActiveBooking: root.dataset.hasActiveBooking === '1',
        urls: {
            calendar: root.dataset.calendarUrl,
            slots: root.dataset.slotsUrl,
            reserve: root.dataset.reserveUrl,
            login: root.dataset.loginUrl,
            clubSignup: root.dataset.clubSignupUrl,
            myBookings: root.dataset.mybookingsUrl,
            cancelMyBooking: root.dataset.cancelMybookingUrl
        },
        viewYear: 0,
        viewMonth: 0,
        selectedDate: null,
        selectedSlots: [],
        slotsAvailable: []
    };
    // Non-club customers can only reserve one slot per booking.
    var singleSlotOnly = ctx.loggedIn && !ctx.isClub;
    var monthNames = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];

    var elTitle = root.querySelector('.ludoteca-cal-title');
    var elDays = root.querySelector('#ludoteca-cal-days');
    var elPrev = root.querySelector('.ludoteca-cal-prev');
    var elNext = root.querySelector('.ludoteca-cal-next');
    var elSlotsSection = root.querySelector('#ludoteca-slots-section');
    var elSlotsGrid = root.querySelector('#ludoteca-slots-grid');
    var elSelectedDate = root.querySelector('#ludoteca-selected-date');
    var elFormSection = root.querySelector('#ludoteca-form-section');
    var elLoginCta = root.querySelector('#ludoteca-login-cta');
    var elForm = root.querySelector('#ludoteca-form');
    var elMsg = elForm ? elForm.querySelector('#ludoteca-form-msg') : null;
    var elSubmit = root.querySelector('#ludoteca-submit');
    var elSubmitHint = root.querySelector('#ludoteca-submit-hint');
    var elTableCount = root.querySelector('#ludoteca-tables-count');

    function setMsg(text, kind) {
        if (!elMsg) { return; }
        elMsg.textContent = text || '';
        elMsg.className = 'ludoteca-form-msg' + (kind ? ' ' + kind : '');
    }

    var today = new Date();
    today.setHours(0, 0, 0, 0);
    ctx.viewYear = today.getFullYear();
    ctx.viewMonth = today.getMonth() + 1;

    function loadMonth() {
        var url = ctx.urls.calendar + '?location_id=' + ctx.locationId + '&year=' + ctx.viewYear + '&month=' + ctx.viewMonth;
        fetch(url, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data || !data.ok) { elDays.innerHTML = ''; return; }
                renderMonth(data.days || {});
            })
            .catch(function () { elDays.innerHTML = ''; });
    }

    function renderMonth(days) {
        elTitle.textContent = monthNames[ctx.viewMonth - 1] + ' ' + ctx.viewYear;
        var first = new Date(ctx.viewYear, ctx.viewMonth - 1, 1);
        var dow = first.getDay();
        var leading = dow === 0 ? 6 : dow - 1;
        var lastDay = new Date(ctx.viewYear, ctx.viewMonth, 0).getDate();
        var html = '';
        for (var i = 0; i < leading; i++) {
            html += '<button class="empty" type="button" disabled aria-hidden="true"></button>';
        }
        for (var d = 1; d <= lastDay; d++) {
            var key = ctx.viewYear + '-' + pad(ctx.viewMonth) + '-' + pad(d);
            var state = days[key] || 'closed';
            var disabled = (state === 'past' || state === 'busy' || state === 'closed' || state === 'not_yet') ? 'disabled' : '';
            var sel = (ctx.selectedDate === key) ? ' selected' : '';
            html += '<button type="button" class="' + state + sel + '" data-date="' + key + '" data-state="' + state + '" ' + disabled + '>' + d + '</button>';
        }
        elDays.innerHTML = html;
        elDays.querySelectorAll('button[data-date]').forEach(function (btn) {
            btn.addEventListener('click', function () { onDayClick(btn); });
        });
    }

    function onDayClick(btn) {
        var state = btn.dataset.state;
        var key = btn.dataset.date;
        if (state === 'out_of_range') {
            if (!ctx.loggedIn) {
                window.location.href = ctx.urls.login;
                return;
            }
            if (ctx.urls.clubSignup) {
                window.location.href = ctx.urls.clubSignup;
            } else {
                setMsg('<?= $escaper->escapeJs(__('Esta fecha sólo está disponible para socios del Club Zacatrus.')) ?>', 'err');
            }
            return;
        }
        if (state === 'past' || state === 'busy' || state === 'closed' || state === 'not_yet') { return; }
        ctx.selectedDate = key;
        ctx.selectedSlots = [];
        elDays.querySelectorAll('button[data-date]').forEach(function (b) { b.classList.toggle('selected', b.dataset.date === key); });
        elSelectedDate.textContent = formatHumanDate(key);
        loadSlots();
    }

    function loadSlots() {
        elSlotsSection.hidden = false;
        elSlotsGrid.innerHTML = '<p>...</p>';
        updateFormVisibility();
        var url = ctx.urls.slots + '?location_id=' + ctx.locationId + '&date=' + ctx.selectedDate;
        fetch(url, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data || !data.ok) { elSlotsGrid.innerHTML = '<p><?= $escaper->escapeJs(__('No se pudo cargar la disponibilidad.')) ?></p>'; return; }
                ctx.slotsAvailable = data.slots || [];
                renderSlots();
            })
            .catch(function () { elSlotsGrid.innerHTML = '<p><?= $escaper->escapeJs(__('Error de red.')) ?></p>'; });
    }

    function renderSlots() {
        if (!ctx.slotsAvailable.length) {
            elSlotsGrid.innerHTML = '<p><?= $escaper->escapeJs(__('No hay turnos disponibles este día.')) ?></p>';
            updateFormVisibility();
            return;
        }
        var requested = parseInt(elTableCount.value, 10);
        var html = '';
        ctx.slotsAvailable.forEach(function (slot) {
            var state, label, disabled;
            if (slot.is_mine) {
                state = 'mine';
                disabled = 'disabled';
                label = '<?= $escaper->escapeJs(__('Reservado por ti')) ?> (' + slot.mine_tables + ')';
            } else if (slot.free_tables < requested) {
                state = 'busy';
                disabled = 'disabled';
                label = slot.free_tables + '/' + slot.total_tables + ' <?= $escaper->escapeJs(__('mesas libres')) ?>';
            } else {
                state = slot.state;
                disabled = '';
                label = slot.free_tables + '/' + slot.total_tables + ' <?= $escaper->escapeJs(__('mesas libres')) ?>';
            }
            var sel = ctx.selectedSlots.indexOf(slot.time_slot_id) >= 0 ? ' selected' : '';
            html += '<button type="button" class="' + state + sel + '" data-id="' + slot.time_slot_id + '" ' + disabled + '>'
                  + formatTime(slot.start_time) + ' – ' + formatTime(slot.end_time)
                  + '<br><small>' + label + '</small>'
                  + '</button>';
        });
        elSlotsGrid.innerHTML = html;
        elSlotsGrid.querySelectorAll('button[data-id]').forEach(function (btn) {
            btn.addEventListener('click', function () { onSlotClick(btn); });
        });
        updateFormVisibility();
    }

    function onSlotClick(btn) {
        var id = parseInt(btn.dataset.id, 10);
        var idx = ctx.selectedSlots.indexOf(id);
        if (idx >= 0) {
            ctx.selectedSlots.splice(idx, 1);
        } else if (singleSlotOnly) {
            // Replace any previously selected slot — non-club allowed only one.
            ctx.selectedSlots = [id];
        } else {
            ctx.selectedSlots.push(id);
        }
        renderSlots();
    }

    function updateFormVisibility() {
        var dayPicked = !!ctx.selectedDate;
        var slotPicked = ctx.selectedSlots.length > 0;
        if (elFormSection) { elFormSection.hidden = !dayPicked; }
        if (elLoginCta) { elLoginCta.hidden = !dayPicked; }
        if (elSubmit) { elSubmit.disabled = !slotPicked; }
        if (elSubmitHint) { elSubmitHint.hidden = slotPicked; }
    }

    if (elForm) elForm.addEventListener('submit', function (e) {
        e.preventDefault();
        setMsg('');
        if (!ctx.loggedIn) {
            window.location.href = ctx.urls.login;
            return;
        }
        if (!ctx.selectedDate || !ctx.selectedSlots.length) { return; }
        var requested = parseInt(elTableCount.value, 10);
        var slots = ctx.selectedSlots.map(function (id) {
            return { time_slot_id: id, tables_count: requested };
        });
        var fd = new FormData();
        fd.append('form_key', root.querySelector('input[name="form_key"]').value);
        fd.append('location_id', ctx.locationId);
        fd.append('booking_date', ctx.selectedDate);
        fd.append('phone_number', root.querySelector('#ludoteca-phone').value);
        slots.forEach(function (s, idx) {
            Object.keys(s).forEach(function (k) { fd.append('slots[' + idx + '][' + k + ']', s[k]); });
        });

        var btn = elForm.querySelector('button[type="submit"]');
        btn.disabled = true;
        fetch(ctx.urls.reserve, { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function (r) { return r.json().then(function (j) { return { status: r.status, body: j }; }); })
            .then(function (res) {
                btn.disabled = false;
                if (res.body && res.body.ok) {
                    setMsg(res.body.message || '<?= $escaper->escapeJs(__('Reserva confirmada.')) ?>', 'ok');
                    ctx.selectedSlots = [];
                    loadMonth();
                    loadSlots();
                    refreshMyBookings();
                } else if (res.body && res.body.error === 'login_required') {
                    window.location.href = res.body.login_url || ctx.urls.login;
                } else {
                    setMsg((res.body && res.body.message) ? res.body.message : '<?= $escaper->escapeJs(__('No se pudo confirmar la reserva.')) ?>', 'err');
                }
            })
            .catch(function () {
                btn.disabled = false;
                setMsg('<?= $escaper->escapeJs(__('Error de red.')) ?>', 'err');
            });
    });

    elPrev.addEventListener('click', function () {
        ctx.viewMonth--;
        if (ctx.viewMonth < 1) { ctx.viewMonth = 12; ctx.viewYear--; }
        loadMonth();
    });
    elNext.addEventListener('click', function () {
        ctx.viewMonth++;
        if (ctx.viewMonth > 12) { ctx.viewMonth = 1; ctx.viewYear++; }
        loadMonth();
    });
    elTableCount.addEventListener('change', function () {
        ctx.selectedSlots = [];
        if (ctx.selectedDate) { renderSlots(); }
    });

    function pad(n) { return n < 10 ? '0' + n : '' + n; }
    function formatTime(t) { return (t || '').substring(0, 5); }
    function formatHumanDate(key) {
        var parts = key.split('-');
        return parts[2] + ' de ' + monthNames[parseInt(parts[1], 10) - 1] + ' de ' + parts[0];
    }

    var I18N = {
        title: '<?= $escaper->escapeJs(__('Tus próximas reservas en esta tienda')) ?>',
        cancel: '<?= $escaper->escapeJs(__('Cancelar reserva')) ?>',
        confirmCancel: '<?= $escaper->escapeJs(__('¿Cancelar esta reserva?')) ?>',
        tables: '<?= $escaper->escapeJs(__('mesa(s)')) ?>'
    };
    function escHtml(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
        });
    }
    function refreshMyBookings() {
        if (!ctx.urls.myBookings || !ctx.loggedIn) { return; }
        var url = ctx.urls.myBookings + (ctx.urls.myBookings.indexOf('?') === -1 ? '?' : '&')
            + 'location_id=' + ctx.locationId;
        fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (data) { renderMyBookings(data && data.items ? data.items : []); })
            .catch(function () {});
    }
    function renderMyBookings(items) {
        var container = document.getElementById('ludoteca-mybookings-container');
        if (!container) { return; }
        if (!items.length) { container.innerHTML = ''; return; }
        var formKey = (root.querySelector('input[name="form_key"]') || {}).value || '';
        var html = '<section class="ludoteca-mybookings">'
            + '<h2 class="ludoteca-mybookings-title">' + escHtml(I18N.title) + '</h2>'
            + '<ul class="ludoteca-mybookings-list">';
        items.forEach(function (b) {
            html += '<li class="ludoteca-mybookings-item">'
                + '<div class="ludoteca-mybookings-info">'
                + '<div class="ludoteca-mybookings-head"><strong>' + escHtml(b.booking_date_human) + '</strong></div>';
            if (b.slots && b.slots.length) {
                html += '<ul class="ludoteca-mybookings-slots">';
                b.slots.forEach(function (s) {
                    html += '<li>' + escHtml(s.start) + ' – ' + escHtml(s.end)
                        + ' · ' + s.tables + ' ' + escHtml(I18N.tables)
                        + '</li>';
                });
                html += '</ul>';
            }
            html += '</div>'
                + '<form method="post" action="' + escHtml(ctx.urls.cancelMyBooking) + '" '
                + 'class="ludoteca-mybookings-cancel-form" '
                + 'onsubmit="return confirm(' + JSON.stringify(I18N.confirmCancel).replace(/&/g, '&amp;').replace(/"/g, '&quot;') + ');">'
                + '<input type="hidden" name="form_key" value="' + escHtml(formKey) + '"/>'
                + '<input type="hidden" name="booking_id" value="' + parseInt(b.booking_id, 10) + '"/>'
                + '<button type="submit" class="ludoteca-mybookings-cancel">' + escHtml(I18N.cancel) + '</button>'
                + '</form>'
                + '</li>';
        });
        html += '</ul></section>';
        container.innerHTML = html;
    }

    loadMonth();
})();
</script>
