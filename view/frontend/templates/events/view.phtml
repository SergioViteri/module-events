<?php
/**
 * @var \Zaca\Events\Block\EventCard $block
 */
$meetId = (int) $block->getRequest()->getParam('id');
if (!$meetId) {
    return;
}

try {
    $meetRepository = $block->getMeetRepository();
    $meet = $meetRepository->getById($meetId);

    if (!$meet->getIsActive()) {
        return;
    }

    $block->setEvent($meet);
} catch (\Exception $e) {
    return;
}

$event = $block->getEvent();
$availableSlots = $block->getAvailableSlots();
$maxSlots = (int) $event->getMaxSlots();
$isRegistered = $block->isCustomerRegistered();
$registrationStatus = $block->getRegistrationStatus();
$availabilityBadge = $block->getAvailabilityBadge();
$themeName = $block->getThemeName();
$typeLabel = $block->getEventTypeLabel();
$shortDate = $block->getShortDateLabel();
$storeName = $block->getStoreName();
$durationMinutes = (int) $event->getDurationMinutes();
$durationText = $durationMinutes > 0 ? (string) __('%1 minutos', $durationMinutes) : '';
$slotsText = $block->getSlotsDisplayMode() !== 'none'
    ? $block->formatSlotsDisplay($availableSlots, $maxSlots) . ' ' . (string) __('plazas libres')
    : '';
$recurrenceShort = $block->getRecurrenceShortLabel();
?>
<div class="zacatrus-events-list event-view-page">
    <div class="event-view-back">
        <a href="<?= $block->escapeUrl($block->getUrl($block->getRoutePath())) ?>">
            ← <?= $block->escapeHtml(__('Volver a los eventos')) ?>
        </a>
    </div>

    <div class="event-view-card event-card" data-meet-id="<?= $block->escapeHtmlAttr($event->getMeetId()) ?>">
        <?php if ($block->getRegistrationConditions() !== ''): ?>
            <div class="registration-conditions" data-meet-id="<?= $block->escapeHtmlAttr($event->getMeetId()) ?>" style="display:none"><?= /* @noEscape */ $block->getRegistrationConditions() ?></div>
        <?php endif; ?>

        <div class="event-tags">
            <?php if ($themeName): ?>
                <span class="event-tag event-tag-main"><?= $block->escapeHtml($themeName) ?></span>
            <?php endif; ?>
            <?php if ($typeLabel): ?>
                <span class="event-tag"><?= $block->escapeHtml($typeLabel) ?></span>
            <?php endif; ?>
            <?php if ($recurrenceShort): ?>
                <span class="event-tag event-tag-recurrence"><?= $block->escapeHtml($recurrenceShort) ?></span>
            <?php endif; ?>
        </div>

        <h1 class="event-view-title"><?= $block->escapeHtml($event->getName()) ?></h1>

        <?php if ($availabilityBadge): ?>
            <span class="event-availability event-availability-<?= $block->escapeHtmlAttr($availabilityBadge['className']) ?>">
                <?= $block->escapeHtml($availabilityBadge['label']) ?>
            </span>
        <?php endif; ?>

        <div class="event-view-meta">
            <?php if ($shortDate): ?>
                <div>
                    <span class="event-meta-icon" aria-hidden="true">📅</span>
                    <span><?= $block->escapeHtml($shortDate) ?></span>
                </div>
            <?php endif; ?>
            <?php if ($storeName): ?>
                <div>
                    <span class="event-meta-icon" aria-hidden="true">📍</span>
                    <span><?= $block->escapeHtml($storeName) ?></span>
                </div>
            <?php endif; ?>
            <?php if ($durationText): ?>
                <div>
                    <span class="event-meta-icon" aria-hidden="true">⏱️</span>
                    <span><?= $block->escapeHtml($durationText) ?></span>
                </div>
            <?php endif; ?>
            <?php if ($slotsText): ?>
                <div>
                    <span class="event-meta-icon" aria-hidden="true">👥</span>
                    <span><?= $block->escapeHtml($slotsText) ?></span>
                </div>
            <?php endif; ?>
            <?php if ($block->hasInfoUrl($event)): ?>
                <div>
                    <a href="<?= $block->escapeUrl($block->getInfoUrl($event)) ?>" target="_blank" class="event-info-link">
                        <?= $block->escapeHtml(__('Event Details')) ?>
                    </a>
                </div>
            <?php endif; ?>
        </div>

        <?php if ($event->getDescription()): ?>
            <div class="event-view-description">
                <?= /* @noEscape */ $block->getDescriptionHtml() ?>
            </div>
        <?php endif; ?>

        <?php if ($isRegistered): ?>
            <div class="event-registration-status">
                <?php if ($registrationStatus === 'waitlist'): ?>
                    <span class="status-waitlist"><?= $block->escapeHtml(__('You are on the waitlist')) ?></span>
                <?php else: ?>
                    <span class="status-confirmed"><?= $block->escapeHtml(__('You are registered')) ?></span>
                <?php endif; ?>
            </div>
        <?php endif; ?>

        <div class="event-view-actions">
            <?php if (!$block->isCustomerLoggedIn()): ?>
                <a href="<?= $block->escapeUrl($block->getLoginUrlWithReturn()) ?>" class="event-action event-action-primary">
                    <?= $block->escapeHtml(__('Iniciar sesión')) ?>
                </a>
            <?php elseif ($isRegistered): ?>
                <?php if ($block->shouldShowQrButton()): ?>
                    <button type="button"
                            class="event-action event-action-secondary qr-button"
                            data-qr-url="<?= $block->escapeUrl($block->getQrCodeUrl()) ?>"
                            data-event-name="<?= $block->escapeHtmlAttr($event->getName()) ?>"
                            data-event-date="<?= $block->escapeHtmlAttr($block->getFormattedEventDate()) ?>">
                        <?= $block->escapeHtml(__('Ver QR')) ?>
                    </button>
                <?php endif; ?>
                <button type="button"
                        class="event-action event-action-danger unregister-btn"
                        data-meet-id="<?= $block->escapeHtmlAttr($event->getMeetId()) ?>"
                        data-url="<?= $block->escapeUrl($block->getUnregisterUrl($event->getMeetId())) ?>">
                    <?= $block->escapeHtml(__('Borrarse')) ?>
                </button>
            <?php elseif ($block->canRegisterForEvent() && $availableSlots > 0): ?>
                <button type="button"
                        class="event-action event-action-primary register-btn"
                        data-meet-id="<?= $block->escapeHtmlAttr($event->getMeetId()) ?>"
                        data-max-attendees="<?= (int) $block->getMaxAttendeesPerRegistration() ?>"
                        data-url="<?= $block->escapeUrl($block->getRegisterUrl($event->getMeetId())) ?>">
                    <?= $block->escapeHtml(__('Reservar plaza')) ?>
                </button>
            <?php elseif ($block->canRegisterForEvent() && $availableSlots <= 0): ?>
                <button type="button"
                        class="event-action event-action-primary register-btn waitlist-btn"
                        data-meet-id="<?= $block->escapeHtmlAttr($event->getMeetId()) ?>"
                        data-max-attendees="<?= (int) $block->getMaxAttendeesPerRegistration() ?>"
                        data-url="<?= $block->escapeUrl($block->getRegisterUrl($event->getMeetId())) ?>">
                    <?= $block->escapeHtml(__('Lista de espera')) ?>
                </button>
            <?php endif; ?>
        </div>

        <?php if ($isRegistered && $block->canShowCalendarLinks()): ?>
            <div class="event-view-extras">
                <div class="calendar-links">
                    <a href="<?= $block->escapeUrl($block->getCalendarIcalUrl()) ?>"><?= $block->escapeHtml(__('iCal')) ?></a>
                    <a href="<?= $block->escapeUrl($block->getCalendarGoogleUrl()) ?>" target="_blank"><?= $block->escapeHtml(__('Add to Google Calendar')) ?></a>
                </div>
                <div class="update-phone-wrapper">
                    <a href="#"
                       class="update-phone-link"
                       data-meet-id="<?= $block->escapeHtmlAttr($event->getMeetId()) ?>"
                       data-url="<?= $block->escapeUrl($block->getUpdatePhoneUrl($event->getMeetId())) ?>">
                        <?= $block->escapeHtml(__('Update Phone Number')) ?>
                    </a>
                </div>
            </div>
        <?php endif; ?>
    </div>
</div>

<script>
require(['domReady!', 'zacatrusEventsRegistration', 'zacatrusEventsQrModal'], function(domReady, registrationHandler, qrModal) {
    try {
        if (registrationHandler && typeof registrationHandler.init === 'function') {
            registrationHandler.init();
        }
    } catch (e) {
        console.error('Error initializing registration handler:', e);
    }
    try {
        if (qrModal && typeof qrModal.init === 'function') {
            qrModal.init();
        }
    } catch (e) {
        console.error('Error initializing QR modal:', e);
    }
});
</script>
