<?php
/**
 * @var \Zaca\Events\Block\EventList $block
 */
?>
<?php if (!$block->isModuleEnabled()): ?>
    <div class="events-disabled-message">
        <div class="message message-notice notice">
            <div><?= $block->escapeHtml(__('Events are currently not available.')) ?>        </div>
    </div>
</div>
<?php else: ?>
<?php
$events = $block->getEvents();
$myRegistrationsMap = $block->getMyRegistrationsMap();
$totalCount = count($events);
$currentLocationSlug = $block->getCurrentLocationSlug();
$currentThemeId = (string) ($block->getRequest()->getParam('theme_id') ?: '');
$currentDateRange = $block->getCurrentDateRange();
$locations = $block->getLocations();
$themes = $block->getThemes();
$routePath = $block->getRoutePath();
$baseListingUrl = $block->getUrl($routePath);
$currentLocation = $block->getCurrentLocation();
$currentCity = $currentLocation ? trim((string) $currentLocation->getCity()) : '';
if ($currentCity !== '') {
    $heroTitle = __('Eventos de juegos de mesa en %1', $currentCity);
    $heroIntro = __('Encuentra partidas, torneos, ligas y presentaciones en %1.', $currentCity);
} else {
    $heroTitle = __('Eventos de juegos de mesa en Zacatrus');
    $heroIntro = __('Encuentra partidas, torneos, ligas y presentaciones en nuestras tiendas físicas.');
}
?>
<div class="zacatrus-events-list">
    <section class="events-hero">
        <div class="events-hero-text">
            <h1 class="events-hero-title"><?= $block->escapeHtml($heroTitle) ?></h1>
            <p class="events-hero-intro"><?= $block->escapeHtml($heroIntro) ?></p>
        </div>
        <div class="events-filter-panel">
            <form method="get"
                  action="<?= $block->escapeUrl($baseListingUrl) ?>"
                  id="events-filter-form"
                  data-base-url="<?= $block->escapeHtmlAttr($baseListingUrl) ?>"
                  data-current-location-slug="<?= $block->escapeHtmlAttr($currentLocationSlug) ?>">
                <?php if ($block->isMyEventsFilterActive()): ?>
                    <input type="hidden" name="my_events" value="1">
                <?php endif; ?>
                <div class="events-controls">
                    <label class="events-field">
                        <span class="events-field-icon" aria-hidden="true">📍</span>
                        <select id="events-location-select" data-events-location="true">
                            <option value="" data-target-url="<?= $block->escapeHtmlAttr($block->getLocationFilterUrl(null)) ?>"><?= $block->escapeHtml(__('Todas las tiendas')) ?></option>
                            <?php if (is_array($locations) || $locations instanceof \Traversable): ?>
                                <?php foreach ($locations as $location): ?>
                                    <?php $locSlug = (string) $location->getUrlKey(); ?>
                                    <option value="<?= $block->escapeHtmlAttr($locSlug) ?>"
                                            data-target-url="<?= $block->escapeHtmlAttr($block->getLocationFilterUrl($location)) ?>"
                                            <?= $currentLocationSlug === $locSlug ? 'selected' : '' ?>>
                                        <?= $block->escapeHtml($location->getName()) ?>
                                    </option>
                                <?php endforeach; ?>
                            <?php endif; ?>
                        </select>
                    </label>
                    <label class="events-field">
                        <span class="events-field-icon" aria-hidden="true">🏷️</span>
                        <select id="events-theme-select" name="theme_id" data-events-filter="true">
                            <option value=""><?= $block->escapeHtml(__('Todos los juegos y temáticas')) ?></option>
                            <?php if (is_array($themes) || $themes instanceof \Traversable): ?>
                                <?php foreach ($themes as $theme): ?>
                                    <option value="<?= $block->escapeHtmlAttr($theme->getThemeId()) ?>"
                                            <?= $currentThemeId === (string) $theme->getThemeId() ? 'selected' : '' ?>>
                                        <?= $block->escapeHtml($theme->getName()) ?>
                                    </option>
                                <?php endforeach; ?>
                            <?php endif; ?>
                        </select>
                    </label>
                    <label class="events-field">
                        <span class="events-field-icon" aria-hidden="true">📅</span>
                        <select id="events-date-select" name="date_range" data-events-filter="true">
                            <option value="all" <?= $currentDateRange === 'all' ? 'selected' : '' ?>><?= $block->escapeHtml(__('Cualquier fecha')) ?></option>
                            <option value="7" <?= $currentDateRange === '7' ? 'selected' : '' ?>><?= $block->escapeHtml(__('Próximos 7 días')) ?></option>
                            <option value="30" <?= $currentDateRange === '30' ? 'selected' : '' ?>><?= $block->escapeHtml(__('Próximos 30 días')) ?></option>
                        </select>
                    </label>
                </div>
                <div class="events-summary">
                    <span class="events-count">
                        <?php if ($totalCount === 1): ?>
                            <?= $block->escapeHtml(__('1 evento encontrado')) ?>
                        <?php else: ?>
                            <?= $block->escapeHtml(__('%1 eventos encontrados', $totalCount)) ?>
                        <?php endif; ?>
                    </span>
                    <a href="<?= $block->escapeUrl($block->getUrl($block->getRoutePath())) ?>" class="events-clear-btn"><?= $block->escapeHtml(__('Limpiar filtros')) ?></a>
                </div>
            </form>
        </div>
    </section>

    <?php if ($block->isCustomerLoggedIn() && $block->getMyEventsCount() > 0): ?>
        <?php $myEventsActive = $block->isMyEventsFilterActive(); ?>
        <div class="my-events-toggle-wrapper">
            <a href="<?= $block->escapeUrl($block->getMyEventsToggleUrl()) ?>"
               class="my-events-chip <?= $myEventsActive ? 'active' : '' ?>"
               aria-pressed="<?= $myEventsActive ? 'true' : 'false' ?>">
                <?php if ($myEventsActive): ?>
                    <?= $block->escapeHtml(__('Show all events')) ?>
                <?php else: ?>
                    <?= $block->escapeHtml(__('Show only your events (%1)', $block->getMyEventsCount())) ?>
                <?php endif; ?>
            </a>
        </div>
    <?php endif; ?>

    <section class="events-wrap">
        <?php if (empty($events)): ?>
            <div class="events-empty">
                <h2><?= $block->escapeHtml(__('No hay eventos con esos filtros')) ?></h2>
                <p><?= $block->escapeHtml(__('Prueba a cambiar la ubicación, ampliar la fecha o seleccionar otra temática.')) ?></p>
                <a href="<?= $block->escapeUrl($block->getUrl($block->getRoutePath())) ?>" class="events-empty-cta"><?= $block->escapeHtml(__('Ver todos los eventos')) ?></a>
            </div>
        <?php else: ?>
            <div class="events-grid">
                <?php foreach ($events as $event): ?>
                    <?php $cardBlock = $block->getChildBlock('zacatrus.events.card'); ?>
                    <?php if ($cardBlock): ?>
                        <?php $cardBlock->setEvent($event); ?>
                        <?php $cardBlock->setData('my_registrations_map', $myRegistrationsMap); ?>
                        <?= $cardBlock->toHtml() ?>
                    <?php endif; ?>
                <?php endforeach; ?>
            </div>
        <?php endif; ?>
    </section>
</div>

<script>
require(['domReady!', 'zacatrusEventsRegistration', 'zacatrusEventsQrModal', 'jquery'], function(domReady, registrationHandler, qrModal, $) {
    try {
        if (registrationHandler && typeof registrationHandler.init === 'function') {
            registrationHandler.init();
        }
    } catch (e) {
        console.error('Error initializing registration handler:', e);
    }
    try {
        if (qrModal && typeof qrModal.init === 'function') {
            qrModal.init();
        }
    } catch (e) {
        console.error('Error initializing QR modal:', e);
    }

    var $filterForm = $('#events-filter-form');

    function buildEventsUrl(targetLocationUrl) {
        var url = targetLocationUrl || $filterForm.data('base-url');
        var params = [];
        var themeId = $('#events-theme-select').val();
        var dateRange = $('#events-date-select').val();
        if (themeId) {
            params.push('theme_id=' + encodeURIComponent(themeId));
        }
        if (dateRange && dateRange !== 'all') {
            params.push('date_range=' + encodeURIComponent(dateRange));
        }
        if ($filterForm.find('input[name="my_events"]').length) {
            params.push('my_events=1');
        }
        return params.length ? url + '?' + params.join('&') : url;
    }

    $('#events-location-select').on('change', function () {
        var target = $(this).find('option:selected').data('target-url') || $filterForm.data('base-url');
        var params = [];
        var themeId = $('#events-theme-select').val();
        var dateRange = $('#events-date-select').val();
        if (themeId) {
            params.push('theme_id=' + encodeURIComponent(themeId));
        }
        if (dateRange && dateRange !== 'all') {
            params.push('date_range=' + encodeURIComponent(dateRange));
        }
        if ($filterForm.find('input[name="my_events"]').length) {
            params.push('my_events=1');
        }
        window.location.href = params.length ? target + '?' + params.join('&') : target;
    });

    $('select[data-events-filter="true"]').on('change', function () {
        // Preserve current location slug by rebuilding the URL from the form base-url
        // plus the currently-selected slug's target URL stored on the location <option>.
        var $selectedLoc = $('#events-location-select').find('option:selected');
        var locTarget = $selectedLoc.data('target-url') || $filterForm.data('base-url');
        window.location.href = buildEventsUrl(locTarget);
    });
});
</script>

<?php endif; ?>
