            <block class="Zaca\Events\Block\Ludoteca\StoreReservation"
                   name="ludoteca.store"
                   template="Zaca_Events::ludoteca/store.phtml"
                   cacheable="false"/>
        </referenceContainer>
    </body>
</page>
