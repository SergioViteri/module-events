<?xml version="1.0"?>
<!--
/**
 * Zacatrus Events Dependency Injection Configuration
 *
 * @category    Zacatrus
 * @package     Zaca_Events
 * @author      Zacatrus
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Zaca\Events\Api\MeetRepositoryInterface" type="Zaca\Events\Model\MeetRepository"/>
    <preference for="Zaca\Events\Api\Data\MeetInterface" type="Zaca\Events\Model\Meet"/>
    <preference for="Zaca\Events\Api\RegistrationRepositoryInterface" type="Zaca\Events\Model\RegistrationRepository"/>
    <preference for="Zaca\Events\Api\Data\RegistrationInterface" type="Zaca\Events\Model\Registration"/>
    <preference for="Zaca\Events\Api\EventTypeRepositoryInterface" type="Zaca\Events\Model\EventTypeRepository"/>
    <preference for="Zaca\Events\Api\ThemeRepositoryInterface" type="Zaca\Events\Model\ThemeRepository"/>
    <preference for="Zaca\Events\Api\Data\ThemeInterface" type="Zaca\Events\Model\Theme"/>
    <preference for="Zaca\Events\Api\LocationRepositoryInterface" type="Zaca\Events\Model\LocationRepository"/>
    <preference for="Zaca\Events\Api\Data\LocationInterface" type="Zaca\Events\Model\Location"/>
    <preference for="Zaca\Events\Api\TimeSlotRepositoryInterface" type="Zaca\Events\Model\Ludoteca\TimeSlotRepository"/>
    <preference for="Zaca\Events\Api\Data\TimeSlotInterface" type="Zaca\Events\Model\Ludoteca\TimeSlot"/>
    <preference for="Zaca\Events\Api\TableBookingRepositoryInterface" type="Zaca\Events\Model\Ludoteca\TableBookingRepository"/>
    <preference for="Zaca\Events\Api\Data\TableBookingInterface" type="Zaca\Events\Model\Ludoteca\TableBooking"/>
    <preference for="Zaca\Events\Api\Data\TableBookingSlotInterface" type="Zaca\Events\Model\Ludoteca\TableBookingSlot"/>
    <preference for="Zaca\Events\Api\TableBookingSlotRepositoryInterface" type="Zaca\Events\Model\Ludoteca\TableBookingSlotRepository"/>
    <preference for="Zaca\Events\Api\Data\TableBookingSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>
    <preference for="Zaca\Events\Api\Data\TableBookingSlotSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>
    <preference for="Zaca\Events\Api\Data\TimeSlotSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>
    
    <!-- Grid Collections -->
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="zacatrus_events_registration_listing_data_source" xsi:type="string">Zaca\Events\Model\ResourceModel\Registration\Grid\Collection</item>
                <item name="zacatrus_events_theme_listing_data_source" xsi:type="string">Zaca\Events\Model\ResourceModel\Theme\Grid\Collection</item>
            </argument>
        </arguments>
    </type>
    
    <virtualType name="zacatrus_events_registration_listing_data_source" type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResultReporting" shared="false">
        <arguments>
            <argument name="collection" xsi:type="object" shared="false">Zaca\Events\Model\ResourceModel\Registration\Grid\Collection</argument>
        </arguments>
    </virtualType>
    
    <virtualType name="zacatrus_events_theme_listing_data_source" type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResultReporting" shared="false">
        <arguments>
            <argument name="collection" xsi:type="object" shared="false">Zaca\Events\Model\ResourceModel\Theme\Grid\Collection</argument>
        </arguments>
    </virtualType>
    
    <!-- Console Commands -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="events_send_reminders" xsi:type="object">Zaca\Events\Console\Command\SendRemindersCommand</item>
                <item name="events_send_ludoteca_reminders" xsi:type="object">Zaca\Events\Console\Command\SendLudotecaRemindersCommand</item>
            </argument>
        </arguments>
    </type>
    
    <!-- Router Plugin for Dynamic Route Path -->
    <type name="Magento\Framework\App\Router\Base">
        <plugin name="zaca_events_router" type="Zaca\Events\Plugin\Router\Base" sortOrder="10"/>
        <plugin name="zaca_ludoteca_router" type="Zaca\Events\Plugin\Router\Ludoteca" sortOrder="20"/>
    </type>

    <!-- Bypass URL rewrite for our events paths so location-slug URLs don't get caught
         by catalog/CMS fuzzy rewrites -->
    <type name="Magento\UrlRewrite\Controller\Router">
        <plugin name="zaca_events_urlrewrite_bypass" type="Zaca\Events\Plugin\Router\UrlRewrite" sortOrder="10"/>
    </type>
</config>

