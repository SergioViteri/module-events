<?xml version="1.0"?>
<!--
/**
 * Zacatrus Events Web API Configuration
 *
 * @category    Zacatrus
 * @package     Zaca_Events
 * @author      Zacatrus
 */
-->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/zacatrus-events/my-registrations" method="GET">
        <service class="Zaca\Events\Api\RegistrationRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="self"/>
        </resources>
    </route>

    <!-- Admin API -->
    <route url="/V1/zacatrus-events/admin/registrations" method="GET">
        <service class="Zaca\Events\Api\RegistrationRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="Zaca_Events::registrations"/>
        </resources>
    </route>

    <route url="/V1/zacatrus-events/admin/meets" method="GET">
        <service class="Zaca\Events\Api\MeetRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="Zaca_Events::meets"/>
        </resources>
    </route>

    <route url="/V1/zacatrus-events/admin/locations" method="GET">
        <service class="Zaca\Events\Api\LocationRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="Zaca_Events::locations"/>
        </resources>
    </route>

    <!-- Ludoteca admin endpoints (used by the Slack /reservas command) -->
    <route url="/V1/zacatrus-events/admin/table-bookings" method="GET">
        <service class="Zaca\Events\Api\TableBookingRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="Zaca_Events::table_bookings"/>
        </resources>
    </route>

    <route url="/V1/zacatrus-events/admin/table-booking-slots" method="GET">
        <service class="Zaca\Events\Api\TableBookingSlotRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="Zaca_Events::table_bookings"/>
        </resources>
    </route>

    <route url="/V1/zacatrus-events/admin/time-slots" method="GET">
        <service class="Zaca\Events\Api\TimeSlotRepositoryInterface" method="getList"/>
        <resources>
            <resource ref="Zaca_Events::time_slots"/>
        </resources>
    </route>
</routes>

